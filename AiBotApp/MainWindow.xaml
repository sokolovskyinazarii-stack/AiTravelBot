<Window
    x:Class="AiBotApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1" Padding="28,22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="50" Height="50" CornerRadius="10" Background="{StaticResource AccentBrush}" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE774;" FontSize="24" Foreground="White" />
                </Border>

                <StackPanel Grid.Column="1" Margin="18,0,20,0" VerticalAlignment="Center">
                    <TextBlock Text="Travel Advisor Bot" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="Чат-консультант для планування подорожей, бюджету, документів і маршруту" Style="{StaticResource CaptionTextStyle}" FontSize="13" Margin="0,4,0,0" />
                </StackPanel>

                <Border Grid.Column="2" Background="{StaticResource AccentSoftBrush}" CornerRadius="8" Padding="14,10" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Режим" Style="{StaticResource CaptionTextStyle}" />
                        <TextBlock Text="OpenAI + fallback" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid x:Name="ContentGrid" Grid.Row="1" Padding="28" SizeChanged="ContentGrid_SizeChanged">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="MainContentRow" Height="*" />
                <RowDefinition x:Name="StackedContentRow" Height="0" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="334" />
                <ColumnDefinition x:Name="WorkspaceColumn" Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer x:Name="SidebarPanel" Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,24,0">
                <StackPanel Spacing="16">
                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel Spacing="14">
                            <StackPanel>
                                <TextBlock Text="Швидкі запити" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Text="Натисніть приклад або напишіть власне питання внизу чату." Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" />
                            </StackPanel>

                            <Button Style="{StaticResource SecondaryButtonStyle}" Click="QuickPrompt_Click" Tag="Куди поїхати на море у вересні?">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE8FD;" FontSize="15" />
                                    <TextBlock Text="Підібрати напрям" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource SecondaryButtonStyle}" Click="QuickPrompt_Click" Tag="Склади маршрут на три дні у Парижі">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE946;" FontSize="15" />
                                    <TextBlock Text="Маршрут" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource SecondaryButtonStyle}" Click="QuickPrompt_Click" Tag="Розрахуй бюджет на двох у Стамбул до 500 євро">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE943;" FontSize="15" />
                                    <TextBlock Text="Бюджет" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource SecondaryButtonStyle}" Click="QuickPrompt_Click" Tag="Які документи потрібні для поїздки в Туреччину?">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="15" />
                                    <TextBlock Text="Документи" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Аналіз запиту" Style="{StaticResource SectionTitleTextStyle}" />
                            <Grid ColumnSpacing="10" RowSpacing="9">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <FontIcon Grid.Row="0" Grid.Column="0" Glyph="&#xE9D2;" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="IntentText" Text="Intent: -" />

                                <FontIcon Grid.Row="1" Grid.Column="0" Glyph="&#xE9D9;" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SidebarConfidenceText" Text="Впевненість: 0%" />

                                <FontIcon Grid.Row="2" Grid.Column="0" Glyph="&#xE787;" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ContextText" Text="Напрям: не обрано" />

                                <FontIcon Grid.Row="3" Grid.Column="0" Glyph="&#xE8D4;" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TechnologyText" Text="Бюджет: не вказано" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Знайдені деталі" Style="{StaticResource SectionTitleTextStyle}" />
                            <ListView x:Name="EntitiesList" MaxHeight="190" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="10" Padding="2,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="6" Padding="7,4">
                                                <TextBlock Text="{Binding Type}" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="SemiBold" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid x:Name="WorkspacePanel" Grid.Row="0" Grid.Column="1" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid x:Name="MetricsGrid" Grid.Row="0" ColumnSpacing="16" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Intent" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock x:Name="MetricIntentText" Text="-" Style="{StaticResource MetricValueTextStyle}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Впевненість" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock x:Name="MetricConfidenceText" Text="0%" Style="{StaticResource MetricValueTextStyle}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Пам'ять діалогу" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock x:Name="MetricMemoryText" Text="напрям не обрано" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,7,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="18">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Чат з туристичним консультантом" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Text="Пишіть довільні питання: бот визначить намір, сутності та збереже контекст." Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="12,8" VerticalAlignment="Center">
                                <TextBlock x:Name="ModelStatusText" Text="Відповідь: локальна модель" Style="{StaticResource CaptionTextStyle}" FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <ListView Grid.Row="1" x:Name="ChatList" MinHeight="0" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,5">
                                        <Border Background="{Binding BubbleBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="13,10" MaxWidth="760" HorizontalAlignment="{Binding Alignment}">
                                            <StackPanel Spacing="5">
                                                <TextBlock Text="{Binding Sender}" Foreground="{Binding SenderBrush}" FontSize="12" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Text}" Foreground="{Binding TextBrush}" FontSize="14" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="MessageTextBox" PlaceholderText="Напишіть питання: куди поїхати, що подивитися, який бюджет або які документи потрібні..." MinHeight="46" KeyDown="MessageTextBox_KeyDown" />
                        <Button x:Name="SendButton" Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}" Click="SendButton_Click" Padding="18,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE724;" FontSize="15" Foreground="White" />
                                <TextBlock Text="Надіслати" Foreground="White" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Grid x:Name="BottomGrid" Grid.Row="3" ColumnSpacing="18" RowSpacing="14" MaxHeight="170">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="BottomSecondRow" Height="0" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="DatasetColumn" Width="1.05*" />
                        <ColumnDefinition x:Name="TraceColumn" Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Модель запитів" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="7 туристичних тем, 84 приклади, OpenAI Responses API для LLM-аналізу і локальний резерв." Style="{StaticResource CaptionTextStyle}" />
                            <ListView x:Name="IntentStatsList" SelectionMode="None" MaxHeight="92">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="12" Padding="4,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="34" Height="28" CornerRadius="7" Background="{StaticResource AccentSoftBrush}">
                                                <TextBlock Text="{Binding Number}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Intent}" VerticalAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="2" Text="{Binding Count}" VerticalAlignment="Center" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border x:Name="TraceCard" Grid.Column="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="9">
                            <TextBlock Text="Журнал обробки" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBox x:Name="TraceTextBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="92" MaxHeight="92" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextBrush}" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource StrokeBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
